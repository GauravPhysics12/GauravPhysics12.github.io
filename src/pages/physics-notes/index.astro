---
import { Container } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';
import { categories } from '../../config/notes.js';

export async function getStaticPaths() {
  return categories.map(category => {
    return {
      params: { slug: category.slug },
      props: { category },
    };
  });
}

const { category } = Astro.props;
---

<Layout title={`${category.name} | Physics Notes`}>
  <section class="hero">
    <Container>
      <nav class="breadcrumb">
        <a href="/physics-notes" class="back-link">&larr; Back to All Notes</a>
      </nav>
      <h1>{category.name}</h1>
      <p class="category-desc">{category.description}</p>
    </Container>
  </section>

  <Container>
    <section class="notes-list">
      {category.notes.map(note => (
        <div class="note-card">
          <div class="note-info">
            <h2>{note.title}</h2>
            {note.comment && <p class="note-comment">{note.comment}</p>}
          </div>
          <div class="note-actions">
            <a href={note.pdfUrl} class="button" target="_blank" rel="noopener noreferrer">
              View PDF
            </a>
          </div>
        </div>
      ))}
    </section>
  </Container>
</Layout>

<style>
  .hero { text-align: center; padding: 4rem 1rem; background-color: var(--theme-bg-offset); }
  
  .breadcrumb { margin-bottom: 1.5rem; }
  
  .back-link {
    display: inline-block;
    color: var(--theme-text-offset);
    text-decoration: none;
    font-size: 0.9rem;
    border: 1px solid var(--theme-border);
    padding: 0.4rem 0.8rem;
    border-radius: 5px;
    transition: all 0.2s ease;
  }
  
  .back-link:hover {
    background-color: var(--theme-surface-1);
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }

  .category-desc {
    max-width: 700px;
    margin: 1rem auto 0;
    line-height: 1.6;
    color: var(--theme-text-offset);
  }

  .notes-list { margin: 3rem auto; max-width: 800px; }
  
  .note-card {
    background-color: var(--theme-surface-1);
    padding: 1.5rem 2rem;
    margin-bottom: 1.5rem;
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    border: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .note-card:hover {
    border-color: var(--theme-accent-alpha, #ccc);
  }

  .note-info h2 { 
    margin: 0; 
    font-size: 1.4rem; 
    color: var(--theme-on-surface-1); 
    line-height: 1.3;
  }
  
  .note-comment {
    font-size: 0.95rem;
    font-style: italic;
    color: var(--theme-text-offset);
    margin: 0.5rem 0 0 0;
    line-height: 1.5;
  }

  .button {
    display: inline-block;
    background-color: var(--theme-accent);
    color: var(--theme-on-primary);
    padding: 12px 24px;
    text-decoration: none;
    border-radius: 5px;
    font-weight: 600;
    transition: background-color 0.2s ease, transform 0.1s ease;
    white-space: nowrap;
  }
  
  .button:hover { 
    background-color: var(--theme-accent-hover); 
    transform: translateY(-1px);
  }

  /* Responsive adjustment for mobile */
  @media (max-width: 600px) {
    .note-card {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.5rem;
    }
    .button {
      width: 100%;
      text-align: center;
    }
  }
</style>